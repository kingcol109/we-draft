{
  "name": "we-draft",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@vercel/analytics": "^1.5.0",
    "ajv": "^8.18.0",
    "ajv-keywords": "^5.1.0",
    "bad-words": "^4.0.0",
    "canvas-confetti": "^1.9.4",
    "core-js-pure": "^3.45.1",
    "firebase": "^11.10.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-helmet-async": "^2.0.5",
    "react-range": "^1.10.0",
    "react-router-dom": "^6.30.1",
    "react-scripts": "5.0.1",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "start": "react-scripts start",
"build": "node scripts/generate-sitemap.js && react-scripts build",
    "postbuild": "react-snap",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "sync": "node sync.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "deploy": "npm run generate-sitemap && firebase deploy"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
"devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "react-snap": "^1.23.0"
  },
  "reactSnap": {
    "puppeteerArgs": ["--no-sandbox"],
    "skipThirdPartyRequests": true,
    "crawl": true,
    "saveAs": "html"
  },
  "overrides": {
    "react-scripts": {
      "typescript": "$typescript"
    }
  }
}
